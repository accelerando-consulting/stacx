        -DTFT_DC=36 -DTFT_RST=34 -DTFT_BL=33 \
        -DSPI_FREQUENCY=40000000 -DSPI_READ_FREQUENCY=20000000 -DSPI_TOUCH_FREQUENCY=2500000

TFTFONTS=-DLOAD_GLCD \
        -DLOAD_FONT2 \
        -DLOAD_FONT4 \
        -DLOAD_FONT6 \
        -DLOAD_FONT7 \
        -DLOAD_FONT8 \
        -DLOAD_GFXFF \
        -DSMOOTH_FONT

CPPFLAGS=-I../.. -I../common
